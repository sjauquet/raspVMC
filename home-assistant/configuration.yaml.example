# Home Assistant example: polls VMCbinjson.cgi once a minute and exposes every
# field as its own sensor. Replace 192.168.xxx.xxx with your Pi's address.
#
# 1) A REST sensor (legacy "platform: rest" style, under the "sensor:" domain)
#    fetches the whole JSON blob and exposes its "config"/"data" keys as
#    attributes on one sensor. The value_template dummy '1' is a workaround:
#    the actual JSON payload is bigger than HA's 255-character state limit, so
#    the real content only lives in the attributes, not the state itself.
# 2) Template sensors below pick individual values out of those attributes.
#
# See docs/PROTOCOL.md for what each field means, and docs/EXTRACTION_MODE.md
# before wiring "Extraction Active" into anything beyond monitoring.

template:
  - sensor:
      # Extraction Active (true = mode extraction seule actif, false = ventilation
      # normale équilibrée). Based on config.ventilateurs.extractionetat, whose raw
      # polarity is counter-intuitive (1=normal, 0=extraction active) - inverted
      # here so the sensor's boolean value matches its name. See
      # docs/EXTRACTION_MODE.md for the full story - monitoring only, do not use
      # this to drive an automation without reading that first.
      - name: "Extraction Active"
        unique_id: "vmcrest_extraction_active"
        state: "{{ state_attr('sensor.all_data_sensor', 'config').ventilateurs.extractionetat | int == 0 }}"

      - name: "Vitesse"
        unique_id: "vmcrest_vitesse"
        unit_of_measurement: "e Vitesse"
        state: "{{ state_attr('sensor.all_data_sensor', 'config').ventilateurs.vitesse }}"

      # Vitesse Adjusted: same value, shifted by -1 (0=absent, 1..3=vitesse 1..3)
      # instead of the raw protocol encoding (1=absent, 2..4=vitesse 1..3).
      - name: "Vitesse Adjusted"
        unique_id: "vmcrest_vitesse_adjusted"
        unit_of_measurement: "e Vitesse"
        state: "{{ (states('sensor.vmcrest_vitesse') | float(0) - 1) | int }}"

      - name: "Bypass Mode"
        unique_id: "vmcrest_bypass_mode"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').bypass.mode }}"

      - name: "Tairneuf Temperature"
        unique_id: "vmcrest_tairneuf_temperature"
        unit_of_measurement: "°C"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').temperature.Tairneuf }}"

      - name: "Tconfort Temperature"
        unique_id: "vmcrest_tconfort_temperature"
        unit_of_measurement: "°C"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').temperature.Tconfort }}"

      - name: "Textrait Temperature"
        unique_id: "vmcrest_textrait_temperature"
        unit_of_measurement: "°C"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').temperature.Textrait }}"

      - name: "Trepris Temperature"
        unique_id: "vmcrest_trepris_temperature"
        unit_of_measurement: "°C"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').temperature.Trepris }}"

      - name: "Tsoufflage Temperature"
        unique_id: "vmcrest_tsoufflage_temperature"
        unit_of_measurement: "°C"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').temperature.Tsoufflage }}"

      - name: "Usage Absent"
        unique_id: "vmcrest_usage_absent"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.absent }}"

      - name: "Antigel"
        unique_id: "vmcrest_antigel"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.antigel }}"

      - name: "Bypass Usage"
        unique_id: "vmcrest_bypass_usage"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.bypass }}"

      - name: "Filtres Usage"
        unique_id: "vmcrest_filtres_usage"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.filtres }}"

      - name: "Vitesse1 Usage"
        unique_id: "vmcrest_vitesse1_usage"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.vitesse1 }}"

      - name: "Vitesse2 Usage"
        unique_id: "vmcrest_vitesse2_usage"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.vitesse2 }}"

      - name: "Vitesse3 Usage"
        unique_id: "vmcrest_vitesse3_usage"
        unit_of_measurement: "Hours"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').usage.vitesse3 }}"

      - name: "Bypass Valve Etat"
        unique_id: "vmcrest_bypass_valve_etat"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').valvesetat.bypass }}"

      - name: "Extraction Pourcent"
        unique_id: "vmcrest_extraction_pourcent"
        unit_of_measurement: "%"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').ventilateurs.extraitpourcent }}"

      - name: "Extraction RPM"
        unique_id: "vmcrest_extraction_rpm"
        unit_of_measurement: "RPM"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').ventilateurs.extraitrpm }}"

      - name: "Soufflage Pourcent"
        unique_id: "vmcrest_soufflage_pourcent"
        unit_of_measurement: "%"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').ventilateurs.soufflagepourcent }}"

      - name: "Soufflage RPM"
        unique_id: "vmcrest_soufflage_rpm"
        unit_of_measurement: "RPM"
        state: "{{ state_attr('sensor.all_data_sensor', 'data').ventilateurs.soufflagerpm }}"

      # Raw JSON Data: handy for debugging in Developer Tools > Template, or for
      # dashboards that want the full structure rather than one sensor per field.
      - name: "VMC Rest API Raw JSON Data"
        unique_id: "vmcrest_raw_json_data"
        state: "{{ state_attr('sensor.all_data_sensor', 'json') }}"
        attributes:
          config: "{{ state_attr('sensor.all_data_sensor', 'config') | tojson }}"
          data: "{{ state_attr('sensor.all_data_sensor', 'data') | tojson }}"

sensor:
  # REST sensor to fetch the JSON data - legacy "platform: rest" style (works
  # across old and current HA versions alike).
  - platform: rest
    resource: http://192.168.xxx.xxx/cgi-bin/VMCbinjson.enhanced.cgi
    name: "All Data Sensor"
    scan_interval: 60
    timeout: 20
    value_template: '1'  # dummy value, not used; avoids the "State max length is 255 characters" error
    json_attributes:
      - config
      - data
